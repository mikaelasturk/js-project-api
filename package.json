{
  "name": "js-project-api",
  "version": "1.0.0",
  "description": "Server part of the JS API project",
  "scripts": {
    "start": "babel-node server.js",
    "dev": "nodemon server.js --exec babel-node",
    "test": "jest",
    "lint": "eslint . --ext .js,.mjs",
    "prettier": "prettier --write .",
    "seed:thoughts": "babel-node seeds/seedThoughts.js",
    "seed:thoughts:reset": "RESET_SEED_DB=true babel-node seeds/seedThoughts.js"
  },
  "scripts-info": {
    "start": "Startar backend-servern i production mode (utan hot-reload)",
    "dev": "Startar backend-servern i utvecklingsläge med nodemon och Babel (hot-reload)",
    "test": "Kör alla Jest unit tests i backend/tests/",
    "lint": "Kör ESLint-kontroll på all backend-kod (.js/.mjs)",
    "prettier": "Formatterar all backend-kod enligt Prettier-konfigurationen (.prettierrc)"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "^7.17.9",
    "@babel/node": "^7.16.8",
    "@babel/preset-env": "^7.16.11",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "express": "^4.22.1",
    "express-list-endpoints": "^7.1.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "mongodb": "^7.3.0",
    "mongoose": "^8.23.0",
    "nodemailer": "^8.0.10",
    "nodemon": "^3.1.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prettier": "^3.8.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  }
}
